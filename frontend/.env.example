# ---------- imrockey frontend env (example) ----------
# Copy this file to `.env` and adjust the API base URL if needed.

VITE_API_BASE_URL=http://127.0.0.1:5001

# ---------- Google Sign-In (R15) ----------
# Web OAuth Client ID from https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins must include this app's origin
# (e.g. http://127.0.0.1:5173 in dev, your prod domain in prod).
# Leave blank to hide the Google button — password login still works.
# The backend reads its own GOOGLE_CLIENT_ID for verification; both must
# point at the same OAuth client.
VITE_GOOGLE_CLIENT_ID=
