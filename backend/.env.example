# ---------- Prompt Package backend env (example) ----------
# Copy this file to `.env` and adjust values as needed.

# Flask runtime
FLASK_ENV=development
FLASK_HOST=127.0.0.1
FLASK_PORT=5001

# Secret key for Flask sessions / signing (replace in production)
SECRET_KEY=change-me-in-production

# Comma-separated list of origins allowed by CORS
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Database — defaults to a SQLite file in backend/instance/promptpackage.sqlite3
# DATABASE_URL=sqlite:///instance/promptpackage.sqlite3

# JWT (used for stateless auth tokens)
JWT_SECRET_KEY=change-me-jwt-secret
JWT_EXPIRES_DAYS=30

# Symmetric encryption key for LLM provider API keys at rest (OpenRouter / DeepSeek / OpenAI).
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank in dev to auto-derive from SECRET_KEY.
# ENCRYPTION_KEY=

# ---------- LLM providers (R14) ----------
# Prompt Package 后端可同时挂多家 provider，每家可覆盖 base URL（私有网关 / 反代用）。
# 默认值留空即可，只在用代理或自建 gateway 时改。
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 探活 / 验证 key 时单次请求的超时（秒）。Chat completions 在 llm_service
# 内部会用到一个 6× 倍数。OPENROUTER_TIMEOUT_SECONDS 是 R12 之前的老名字，
# 仍然兼容，但优先读 LLM_VERIFY_TIMEOUT_SECONDS。
OPENROUTER_TIMEOUT_SECONDS=10
LLM_VERIFY_TIMEOUT_SECONDS=10

# ---------- Google Sign-In (R15) ----------
# Web OAuth Client ID from https://console.cloud.google.com/apis/credentials
# (Application type = Web application; Authorized JavaScript origins must
# include your frontend origin, e.g. http://127.0.0.1:5173).
# Leave blank to disable Google login (form login keeps working).
# Frontend reads its own VITE_GOOGLE_CLIENT_ID; the backend uses this one
# only to verify id_token audience.
GOOGLE_CLIENT_ID=
