# Prompt Package — docker-compose env template.
#
# Copy this to ``.env`` (sibling of docker-compose.yml) and edit the
# values. The compose file reads ${…} interpolations from that .env
# automatically, so you can `docker compose up -d` without wrapping
# every command in `docker compose --env-file`.
#
#   cp .env.docker.example .env
#   # then edit
#   docker compose up -d --build

# ---------- Host-side bindings ----------
# Port the frontend nginx listens on (outside the container).
# Defaults to 8080 so it doesn't collide with a host-level nginx on 80.
HOST_PORT=8080

# ---------- Backend runtime ----------
# development   = dev config, three secrets below may be placeholders
# production    = ProductionConfig; REFUSES TO BOOT if any secret is still default
FLASK_ENV=development

# Used by Flask for session cookies + CSRF-style signing. Any long
# random string works. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
SECRET_KEY=change-me-in-production

# JWT signing key for stateless auth tokens. Same generator as above.
JWT_SECRET_KEY=change-me-jwt-in-production

# How many days a JWT stays valid.
JWT_EXPIRES_DAYS=30

# Fernet symmetric key used to encrypt users' LLM provider API keys at
# rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leaving it blank in dev makes the backend derive a key from SECRET_KEY;
# production REQUIRES a real value — don't ship the default.
ENCRYPTION_KEY=

# Comma-separated list of origins the backend will trust for CORS.
# When you use the bundled nginx reverse proxy (the default), the
# browser makes same-origin requests and this doesn't matter. If you
# instead host the frontend on a different origin and point its
# VITE_API_BASE_URL at the backend, list that origin here.
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# ---------- Database ----------
# Leave blank to use the bundled SQLite (persisted on the
# `prompt-package-data` named volume). Override to switch to Postgres:
#   DATABASE_URL=postgresql://user:pass@db:5432/promptpackage
DATABASE_URL=

# ---------- LLM providers ----------
# Only change these to route LLM traffic through a private gateway or
# reverse proxy. The defaults hit the official endpoints.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_VERIFY_TIMEOUT_SECONDS=10

# ---------- Google Sign-In (optional) ----------
# Web OAuth Client ID (Google Cloud Console → Credentials). When set,
# Login / Register pages render the official Google button. Frontend
# and backend MUST share the same value.
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# ---------- Frontend build args ----------
# Leave VITE_API_BASE_URL blank when using the bundled nginx proxy —
# the frontend will call /api/... relative paths that nginx forwards
# to the backend service. Set to a full https URL only if you host
# the frontend on a different origin without an nginx middle tier.
VITE_API_BASE_URL=
# VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
